# ElderPhoto — environment variable template
# Copy to .env.local and fill in the values.

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# Base URL of the backend API (no trailing slash).
# In development the Vite dev server proxies /api → http://localhost:8000,
# so you can leave this commented out.
# VITE_API_URL=http://localhost:8000

# ── Backend ──────────────────────────────────────────────────────────────────
# Directory where uploaded photos are stored.
# UPLOAD_DIR=/var/lib/elderphoto/uploads

# Source and destination directories used by the backup sync task.
# BACKUP_SOURCE_DIR=/var/lib/elderphoto/uploads
# BACKUP_DEST_DIR=/var/lib/elderphoto/backup

# Comma-separated list of allowed CORS origins.
# CORS_ALLOWED_ORIGINS=https://your-domain.com

# ── External services ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_api_key_here
